# Anthropic API key (required for search, scanning, and auto-translation)
ANTHROPIC_API_KEY=sk-your-api-key

# Anthropic API endpoint (optional, defaults to https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# GitHub token (optional, increases API rate limit from 60 to 5000 req/hr)
# GITHUB_TOKEN=ghp_xxx
